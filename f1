-- 7. RIDE DRAGON
----------------------------------------------------
if CONFIG.RIDE_DRAGON then
    local function rideDragon()
        local okS, Sonar = pcall(require, RS:WaitForChild("Sonar", 10))
        if not okS or not Sonar then
            warn("[s1] require Sonar fail:", Sonar)
            return false
        end

        local okMod, PlayerWrapper, DragonClassClient, DragonService, RemoteUtils = pcall(function()
            return Sonar("PlayerWrapper"), Sonar("DragonClassClient"),
                   Sonar("DragonService"),  Sonar("RemoteUtils")
        end)
        if not okMod then
            warn("[s1] load Sonar modules fail:", PlayerWrapper)
            return false
        end

        local client = PlayerWrapper.GetClient()
        pcall(function() client:yieldForCharacter() end)
        task.wait(1)

        local dragonVal = client.PlayerData
            and client.PlayerData:FindFirstChild("Dragons")
            and client.PlayerData.Dragons:FindFirstChild("1")
        if not dragonVal then
            warn("[s1] ไม่เจอ dragon slot 1")
            return false
        end

        if not DragonService.CanEquipDragon(dragonVal, client) then
            warn("[s1] CanEquipDragon=false (unequip zone?)")
            return false
        end

        local EquipRemote = RemoteUtils.GetRemoteFunction("EquipDragonRemote")
        local okE, success = pcall(EquipRemote.InvokeServer, EquipRemote, "1")
        if not okE   then warn("[s1] equip remote error:", success) return false end
        if not success then warn("[s1] equip return false") return false end

        if DragonService.IsDragonDead(dragonVal) then
            warn("[s1] dragon ตาย — ไม่ mount")
            return false
        end

        DragonClassClient.MountDragonFromValue(dragonVal)
        return true
    end

    local _rideT = tick()
    while not isLoadingDone() and tick() - _rideT < 30 do task.wait(0.5) end
    task.wait(2)
    if rideDragon() then
        print("[s1] ✅ Riding dragon")
    else
        print("[s1] ⚠ Ride dragon fail (จะข้าม)")
    end
end

