local function isLoadingDone()
    local okCI, ci = pcall(function() return LP:GetAttribute("ClientInitiated") end)
    if okCI and ci ~= true then return false end
    local okDS, syncing = pcall(function() return LP:GetAttribute("DataSyncing") end)
    if okDS and syncing then return false end
    local pg = LP:FindFirstChild("PlayerGui")
    if pg then
        local lg = pg:FindFirstChild("LoadingScreen")
        if lg and lg.Enabled then return false end
    end
    return true
end

