----------------------------------------------------
-- 8.5. AUTO-CLAIM SEASON MISSIONS (Daily/Weekly) — event-driven
----------------------------------------------------
-- verified: RS.Remotes.ClaimSeasonMissionRemote:InvokeServer(typeIdx, missionIdx)
-- typeIdx → Daily=1, Weekly=2
-- structure: LP.Data.Seasons.Missions.{Daily/Weekly}.<index>
-- เงื่อนไข: ต้องอยู่ guild แล้ว
do
    local guild = LP.Data and LP.Data:FindFirstChild("Guild")
    local current = guild and guild.Value or ""
    if current == "" then
        print("[s1] ⏭ ไม่อยู่ guild → skip auto-claim season missions")
    else
        local claimRemote = remotes and remotes:FindFirstChild("ClaimSeasonMissionRemote")
        local seasonsData = LP.Data and LP.Data:FindFirstChild("Seasons")
        local missionsRoot = seasonsData and seasonsData:FindFirstChild("Missions")

        if not (claimRemote and missionsRoot) then
            warn("[s1] ⚠ ClaimSeasonMissionRemote หรือ Data.Seasons.Missions ไม่เจอ — skip")
        else
            local TYPE_MAP = { Daily = 1, Weekly = 2 }

            local function tryClaim(mission, typeName, typeIdx)
                local comp = mission:FindFirstChild("Completed")
                local claimedV = mission:FindFirstChild("Claimed")
                if not (comp and comp.Value and claimedV and not claimedV.Value) then return end
                local idx = tonumber(mission.Name)
                if not idx then return end
                local ok, result = pcall(function()
                    return claimRemote:InvokeServer(typeIdx, idx)
                end)
                if ok and result == true then
                    print(("[s1] ✅ claimed %s.%s (typeIdx=%d, idx=%d)"):format(typeName, mission.Name, typeIdx, idx))
                else
                    warn(("[s1] ⚠ claim fail %s.%s — ok=%s result=%s"):format(
                        typeName, mission.Name, tostring(ok), tostring(result)))
                end
            end

            local function hookMission(mission, typeName, typeIdx)
                tryClaim(mission, typeName, typeIdx)
                local comp = mission:FindFirstChild("Completed")
                if comp then
                    comp:GetPropertyChangedSignal("Value"):Connect(function()
                        tryClaim(mission, typeName, typeIdx)
                    end)
                end
            end

            local function hookType(typeName, typeIdx)
                local typeFolder = missionsRoot:FindFirstChild(typeName)
                if not typeFolder then
                    warn(("[s1] ⚠ Missions.%s ไม่เจอ"):format(typeName))
                    return
                end
                for _, m in ipairs(typeFolder:GetChildren()) do
                    task.spawn(hookMission, m, typeName, typeIdx)
                end
                typeFolder.ChildAdded:Connect(function(m)
                    hookMission(m, typeName, typeIdx)
                end)
            end

            for typeName, typeIdx in pairs(TYPE_MAP) do
                hookType(typeName, typeIdx)
            end
            print("[s1] ✅ Season mission auto-claim hooked (Daily + Weekly)")
        end
    end
end

----------------------------------------------------
-- 8.6. AUTO-CLAIM GUILD TASKS (event-driven, ไม่ polling)
----------------------------------------------------
-- Listen Completed:GetPropertyChangedSignal("Value") ของ task ทุกตัวใน PointTasks
-- เงื่อนไข: ต้องอยู่ guild
do
    local guild = LP.Data and LP.Data:FindFirstChild("Guild")
    local current = guild and guild.Value or ""
    if current == "" then
        print("[s1] ⏭ ไม่อยู่ guild → skip auto-claim guild tasks")
    else
        local claimRemote = remotes and remotes:FindFirstChild("ClaimGuildTaskRemote")
        local g  = LP.Data and LP.Data:FindFirstChild("Guild")
        local pt = g and g:FindFirstChild("PointTasks")
        if not pt then
            local gv = LP:FindFirstChild("GuildValue")
            pt = gv and gv:FindFirstChild("PointTasks")
        end

        if not (claimRemote and pt) then
            warn("[s1] ⚠ ClaimGuildTaskRemote หรือ PointTasks ไม่เจอ — skip")
        else
            local function tryClaim(task_)
                local completed = task_:FindFirstChild("Completed")
                local claimedV  = task_:FindFirstChild("Claimed")
                if completed and completed.Value and claimedV and not claimedV.Value then
                    local ok = pcall(function() claimRemote:InvokeServer(task_.Name) end)
                    if ok then
                        print(("[s1] ✅ claimed guild task [%s]"):format(task_.Name))
                    else
                        warn(("[s1] ⚠ claim guild task [%s] fail"):format(task_.Name))
                    end
                end
            end

            local function hookTask(task_)
                local completed = task_:WaitForChild("Completed", 5)
                if not completed then return end
                tryClaim(task_)
                completed:GetPropertyChangedSignal("Value"):Connect(function()
                    tryClaim(task_)
                end)
            end

            for _, t in ipairs(pt:GetChildren()) do
                task.spawn(hookTask, t)
            end
            pt.ChildAdded:Connect(hookTask)

            print(("[s1] ✅ Guild task auto-claim hooked (%d tasks)"):format(#pt:GetChildren()))
        end
    end
end

