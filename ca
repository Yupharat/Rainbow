-- AUTO-CLAIM GUILD TASKS (event-driven, ไม่ polling)
----------------------------------------------------
-- Listen Completed:GetPropertyChangedSignal("Value") ของ task ทุกตัวใน PointTasks
-- → fire ทันทีตอน server set Completed=true → claim ทันที
-- + ChildAdded ดักจับ task ใหม่ที่ replicate มา (weekly refresh)
-- เงื่อนไข: ต้องอยู่ guild
do
    local guild = LP.Data and LP.Data:FindFirstChild("Guild")
    local current = guild and guild.Value or ""
    if current == "" then
        print("⏭ ไม่อยู่ guild → skip auto-claim guild tasks")
    else
        local remotes = RS:WaitForChild("Remotes", 10)
        local claimRemote = remotes and remotes:FindFirstChild("ClaimGuildTaskRemote")
        local g  = LP.Data and LP.Data:FindFirstChild("Guild")
        local pt = g and g:FindFirstChild("PointTasks")
        if not pt then
            local gv = LP:FindFirstChild("GuildValue")
            pt = gv and gv:FindFirstChild("PointTasks")
        end

        if not (claimRemote and pt) then
            warn("⚠ ClaimGuildTaskRemote หรือ PointTasks ไม่เจอ — skip")
        else
            local function tryClaim(task_)
                local completed = task_:FindFirstChild("Completed")
                local claimedV  = task_:FindFirstChild("Claimed")
                if completed and completed.Value and claimedV and not claimedV.Value then
                    local ok = pcall(function() claimRemote:InvokeServer(task_.Name) end)
                    if ok then
                        print(("✅ claimed guild task [%s]"):format(task_.Name))
                    else
                        warn(("⚠ claim guild task [%s] fail"):format(task_.Name))
                    end
                end
            end

            local function hookTask(task_)
                local completed = task_:WaitForChild("Completed", 5)
                if not completed then return end
                tryClaim(task_)   -- เผื่อ completed=true อยู่แล้วตอน hook
                completed:GetPropertyChangedSignal("Value"):Connect(function()
                    tryClaim(task_)
                end)
            end

            -- hook task ปัจจุบันทุกตัว
            for _, t in ipairs(pt:GetChildren()) do
                task.spawn(hookTask, t)
            end
            -- ดักจับ task ใหม่ที่ replicate มา (weekly refresh)
            pt.ChildAdded:Connect(hookTask)

            print(("✅ Guild task auto-claim hooked (%d tasks)"):format(#pt:GetChildren()))
        end
    end
end

-- เช็ค missions ที่ยังไม่เสร็จ (KillBoss ไว้สุดท้าย)
local missions = getIncompleteMissions(worldName)
table.sort(missions, function(a, b)
    if a == "KillBoss" then return false end
    if b == "KillBoss" then return true end
    return a < b
end)
if #missions == 0 then
    print("✅ ทุก mission เสร็จแล้ว — หยุด")
    return
end

print(string.format("📋 %d mission ที่ยังไม่เสร็จ: %s", #missions, table.concat(missions, ", ")))

-- ทำทีละตัว
for _, missionName in ipairs(missions) do
    if isMissionDone(worldName, missionName) then
        print("⏭ ข้าม (เสร็จแล้ว):", missionName)
        continue
    end

    local fn = FARM_MAP[missionName]
    if fn then
        fn(worldName)
    else
        print("⚠️ ไม่มี farm fn:", missionName)
    end

    task.wait(1)
end

print("🏁 ทำ mission ครบทุกตัวแล้ว — หยุดสคริป")
