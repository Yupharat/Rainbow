local function getRoot()
    local c = LP.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getDragon()
    local c = LP.Character
    if not c then return nil, nil end
    local d = c:FindFirstChild("Dragons") and c.Dragons:FindFirstChild("1")
    if not d then return nil, nil end
    local r = d:FindFirstChild("Remotes")
    if not r then return nil, nil end
    return r:FindFirstChild("BreathFireRemote"), r:FindFirstChild("PlaySoundRemote")
end

local function isMissionDone(worldName, missionName)
    local wm = LP:FindFirstChild("Data")
        and LP.Data:FindFirstChild("WorldMissions")
        and LP.Data.WorldMissions:FindFirstChild(worldName)
        and LP.Data.WorldMissions[worldName]:FindFirstChild("Missions")
        and LP.Data.WorldMissions[worldName].Missions:FindFirstChild(missionName)
    return wm and wm.Value == true
end

local function getIncompleteMissions(worldName)
    local list = {}
    local folder = LP:FindFirstChild("Data")
        and LP.Data:FindFirstChild("WorldMissions")
        and LP.Data.WorldMissions:FindFirstChild(worldName)
        and LP.Data.WorldMissions[worldName]:FindFirstChild("Missions")
    if not folder then return list end
    for _, m in ipairs(folder:GetChildren()) do
        if m.Value ~= true then
            table.insert(list, m.Name)
        end
    end
    return list
end

-- Mob: Dex โครงสร้างใหม่ = workspace.Interactions.Nodes.Mobs.<Model>
-- เก่า = workspace.MobFolder.<folder> + part ชื่อเดียวกับ folder
local function mobPartLooksAlive(part)
    if not part or not part:IsA("BasePart") then return false end
    local hp = part:FindFirstChild("Health")
    local dead = part:FindFirstChild("Dead")
    if not hp or not hp:IsA("ValueBase") or hp.Value <= 0 then return false end
    if dead and dead:IsA("BoolValue") and dead.Value then return false end
    return true
end

local function getMobHitPart(mobRoot)
    if not mobRoot then return nil end
    if mobRoot:IsA("BasePart") and mobPartLooksAlive(mobRoot) then return mobRoot end
    local byName = mobRoot:FindFirstChild(mobRoot.Name)
    if byName and byName:IsA("BasePart") and mobPartLooksAlive(byName) then return byName end
    if mobRoot:IsA("Model") and mobRoot.PrimaryPart and mobPartLooksAlive(mobRoot.PrimaryPart) then
        return mobRoot.PrimaryPart
    end
    for _, d in ipairs(mobRoot:GetDescendants()) do
        if d:IsA("BasePart") and mobPartLooksAlive(d) then return d end
    end
    return nil
end

local function findNearestMobPart()
    local root = getRoot()
    if not root then return nil end
    local nearest, minDist = nil, math.huge
    local function consider(mobRoot)
        local part = getMobHitPart(mobRoot)
        if part then
            local d = (root.Position - part.Position).Magnitude
            if d < minDist then minDist = d nearest = part end
        end
    end
    local nodes = workspace:FindFirstChild("Interactions")
        and workspace.Interactions:FindFirstChild("Nodes")
    local nm = nodes and nodes:FindFirstChild("Mobs")
    if nm then
        for _, child in ipairs(nm:GetChildren()) do consider(child) end
    end
    local mf = workspace:FindFirstChild("MobFolder")
    if mf then
        for _, child in ipairs(mf:GetChildren()) do consider(child) end
    end
    return nearest
end

