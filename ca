local function farmTreasureChest(worldName)
    print("💰 TreasureChest")

    local waypoints = CHEST_WAYPOINTS[worldName] or {}
    local wpIdx = 1
    local skipPositions = {}   -- positionPart.Name ที่ server reject → ไม่ลองอีก

    -- ★ TreasureChestDropsRemote อยู่ที่ RS.Remotes ไม่ใช่ RS ตรง (dump 118295 RemoteUtils)
    local dropRemote = RS:WaitForChild("Remotes", 10):FindFirstChild("TreasureChestDropsRemote")
    if dropRemote then
        dropRemote.OnClientEvent:Connect(function(chestValue, drops)
            for itemIdx in pairs(drops) do
                task.wait(0.05)
                pcall(function() dropRemote:FireServer(chestValue, itemIdx) end)
            end
        end)
        print("💰 TreasureChestDropsRemote connected")
    else
        warn("💰 ไม่เจอ RS.Remotes.TreasureChestDropsRemote")
    end

    -- ★ count chests ที่ server confirmed opened (ใน LP.Data.TreasureChests.<world>)
    --   ใช้เช็คว่า Dead=true ทำให้เปิดสำเร็จมั้ย (dump 161595, verified check_chest_spawns.lua)
    local function countOpened()
        local pd = LP:FindFirstChild("Data")
        local tcFolder = pd and pd:FindFirstChild("TreasureChests")
        local worldFolder = tcFolder and tcFolder:FindFirstChild(worldName)
        if not worldFolder then return 0 end
        local n = 0
        for _, v in ipairs(worldFolder:GetChildren()) do
            if v.Value == true then n += 1 end
        end
        return n
    end

    local function findChest()
        local root = getRoot()
        if not root then return nil end
        local nearest, minDist = nil, math.huge
        local function checkPart(pos)
            if not pos:IsA("BasePart") then return end
            if skipPositions[pos.Name] then return end
            local model = pos:FindFirstChildWhichIsA("Model")
            if not model or not model.PrimaryPart then return end
            local dead = model.PrimaryPart:FindFirstChild("Dead")
            if dead and dead.Value then return end
            local body   = model:FindFirstChild("Body")
            local opened = body and body:FindFirstChild("Opened")
            local rays   = opened and opened:FindFirstChild("Rays")
            if rays and rays.Enabled == true then return end
            local d = (root.Position - model.PrimaryPart.Position).Magnitude
            if d < minDist then
                minDist = d
                nearest = { model = model, part = model.PrimaryPart, positionPart = pos }
            end
        end
        local CS = game:GetService("CollectionService")
        local tagged = CS:GetTagged("TreasureChestPosition")
        if #tagged > 0 then
            for _, pos in ipairs(tagged) do checkPart(pos) end
        else
            local folder = workspace:FindFirstChild("Interactions")
                and workspace.Interactions:FindFirstChild("Nodes")
                and workspace.Interactions.Nodes:FindFirstChild("Treasure")
            if folder then
                for _, pos in ipairs(folder:GetChildren()) do checkPart(pos) end
            end
        end
        return nearest
    end

    -- ★ Open flow (verified จาก dump 299266-299287):
    --   1. Set PrimaryPart.Dead.Value=true → fires Dead changed signal → animation
    --   2. Track.KeyframeReached("End") → game fire OpenChestRemote(idx, IsEventChest) เอง
    --   3. Server validate ตำแหน่ง + opens → ChestValue.Value=true ใน LP.Data
    --   หรือ server reject → Dead.Value=false (dump 299280) = locked/invalid
    --   เราแค่ trigger Dead=true + watch LP.Data count → ไม่ต้องเรียก remote เอง
    local DEAD_WAIT = 10   -- timeout รอ ChestValue flip (animation 3-5s + RTT)
    local function openChest(chest)
        if not chest or not chest.part then return false, "no chest" end
        local dead = chest.part:FindFirstChild("Dead")
        if not dead then
            for _ = 1, 25 do
                dead = chest.part:FindFirstChild("Dead")
                if dead then break end
                task.wait(0.2)
            end
        end
        if not dead then return false, "no Dead value (streaming?)" end
        if dead.Value then return true, "already dead" end

        local beforeOpened = countOpened()
        pcall(function() dead.Value = true end)
        print("💰 Dead=true →", chest.model.Name)

        local t0 = tick()
        while tick() - t0 < DEAD_WAIT do
            if countOpened() > beforeOpened then
                return true, ("opened (%.1fs)"):format(tick() - t0)
            end
            if not dead.Value then
                return false, ("REJECTED (Dead reverted %.1fs)"):format(tick() - t0)
            end
            task.wait(0.1)
        end
        return false, ("timeout %ds"):format(DEAD_WAIT)
    end

    -- TP จุดแรก
    if #waypoints > 0 then
        local r = getRoot()
        if r then r.CFrame = CFrame.new(waypoints[wpIdx] + Vector3.new(0, 10, 0)) end
        task.wait(2)
    end

    while not isMissionDone(worldName, "TreasureChest") do
        local chest = findChest()
        local root  = getRoot()
        if chest and root then
            pcall(function()
                root.CFrame = CFrame.new(
                    chest.part.Position + Vector3.new(0, 5, 0),
                    chest.part.Position
                )
            end)
            task.wait(0.8)   -- รอ Dead replicate

            local ok, msg = openChest(chest)
            if ok then
                print(("  ✅ %s"):format(msg))
            else
                warn(("  ❌ pos=%s: %s"):format(chest.positionPart.Name, msg))
                if msg:find("REJECTED") or msg:find("no Dead") then
                    skipPositions[chest.positionPart.Name] = true
                end
            end
        else
            -- ไม่เจอกล่อง → TP ไป waypoint ถัดไป
            if #waypoints > 0 then
                task.wait(2)
                wpIdx = wpIdx % #waypoints + 1
                local r = getRoot()
                if r then r.CFrame = CFrame.new(waypoints[wpIdx] + Vector3.new(0, 10, 0)) end
                task.wait(1)
            else
                task.wait(1)
            end
        end
    end

    print("✅ TreasureChest done")
end

