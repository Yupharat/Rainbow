-- HOOK: AntiKick + AntiAFK + GodMode + AntiMetrics
----------------------------------------------------
pcall(function()
    local remotes   = RS:WaitForChild("Remotes", 10)
    local afkRemote = remotes and remotes:WaitForChild("SetLastPlayedUpdateRemote", 5)
    local mobRemote = remotes and remotes:FindFirstChild("MobDamageRemote")

    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    local _orig = mt.__namecall
    mt.__namecall = function(self, ...)
        if not checkcaller() then
            local m = getnamecallmethod()
            if m == "Kick" then return nil end
            if m == "FireServer" and self.Name == "EventExportClientMetrics" then return end
            if m == "FireServer" and afkRemote and self == afkRemote then return end
            if (m == "FireServer" or m == "InvokeServer") and mobRemote and self == mobRemote then
                local args = {...}
                local char = LP and LP.Character
                local drag = char and char:FindFirstChild("Dragons")
                if drag and args[1] and args[1].Parent == drag then return end
            end
        end
        return _orig(self, ...)
    end
    setreadonly(mt, true)
end)
print("🛡️ Hook ON")

