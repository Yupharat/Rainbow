local _SonarMod, _PW, _DCC, _DS, _RU
local function _loadSonar()
    if _SonarMod then return true end
    local okS, Sonar = pcall(require, RS:WaitForChild("Sonar", 10))
    if not okS or not Sonar then return false end
    local okMod, PW, DCC, DS, RU = pcall(function()
        return Sonar("PlayerWrapper"), Sonar("DragonClassClient"),
               Sonar("DragonService"),  Sonar("RemoteUtils")
    end)
    if not okMod then return false end
    _SonarMod, _PW, _DCC, _DS, _RU = Sonar, PW, DCC, DS, RU
    return true
end

local function isMounted()
    if not _loadSonar() then return false end
    local client = _PW.GetClient()
    return client ~= nil and client.CurrentDragon ~= nil
end

local function mountDragon()
    if not _loadSonar() then warn("[mount] Sonar load fail") return false end
    local client = _PW.GetClient()
    pcall(function() client:yieldForCharacter() end)

    local dragonVal = client.PlayerData
        and client.PlayerData:FindFirstChild("Dragons")
        and client.PlayerData.Dragons:FindFirstChild("1")
    if not dragonVal then warn("[mount] ไม่เจอ dragon slot 1") return false end

    if _DS.IsDragonDead(dragonVal) then warn("[mount] dragon dead") return false end

    -- ★ ถ้า dragon equipped อยู่แล้ว → MountDragonFromValue ตรงๆ (skip equip)
    --   เพราะ boss instance = unequip zone (CanEquipDragon=false) ตอนตกจาก seat
    --   dump line 290025: MountDragonFromValue → getDragonFromDataValue → _sit
    local char = LP.Character
    local equipped = char and char:FindFirstChild("Dragons") and char.Dragons:FindFirstChild("1")
    if equipped then
        task.spawn(function()
            pcall(function() _DCC.MountDragonFromValue(dragonVal, true) end)
        end)
        return true
    end

    -- ยังไม่ equipped → ต้อง equip ก่อน (เฉพาะ world ปกติ ที่ CanEquipDragon=true)
    if not _DS.CanEquipDragon(dragonVal, client) then
        warn("[mount] CanEquipDragon=false + ไม่มี equipped dragon")
        return false
    end

    local EquipRemote = _RU.GetRemoteFunction("EquipDragonRemote")
    local okE, success = pcall(EquipRemote.InvokeServer, EquipRemote, "1")
    if not okE or not success then warn("[mount] equip fail") return false end

    task.spawn(function()
        pcall(function() _DCC.MountDragonFromValue(dragonVal, true) end)
    end)
    return true
end

