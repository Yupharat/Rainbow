-- RidingRing
local function farmRidingRing(worldName)
    print("🎯 RidingRing")
    local ringRemote = RS.Remotes:FindFirstChild("RidingRingTouchedRemote")

    local function findRing()
        local root = getRoot()
        if not root then return nil end
        local folder = workspace:FindFirstChild("Interactions")
            and workspace.Interactions:FindFirstChild("RidingRings")
            and workspace.Interactions.RidingRings:FindFirstChild("CreatedRings")
        if not folder then return nil end
        local nearest, minDist = nil, math.huge
        for _, ring in ipairs(folder:GetChildren()) do
            if ring:IsA("BasePart") and ring.BrickColor.Name == "Fawn brown" and ring.Size.Y > 100 then
                local d = (root.Position - ring.Position).Magnitude
                if d < minDist and d < 750 then minDist = d nearest = ring end
            end
        end
        return nearest
    end

    while not isMissionDone(worldName, "RidingRing") do
        local ring = findRing()
        if ring then
            local root = getRoot()
            if root then
                local start = root.Position
                local dist  = (ring.Position - start).Magnitude
                local dur   = dist / 150
                local elapsed, conn = 0, nil
                conn = RunService.Heartbeat:Connect(function(dt)
                    elapsed += dt
                    local r = getRoot()
                    if not r then conn:Disconnect() return end
                    r.CFrame = CFrame.new(start:Lerp(ring.Position, math.min(elapsed/dur, 1)))
                    if elapsed >= dur then conn:Disconnect() end
                end)
                task.wait(dur + 0.3)
                if ringRemote then pcall(function() ringRemote:FireServer(ring) end) end
                task.wait(0.5)
            end
        else
            task.wait(1)
        end
    end
    print("✅ RidingRing done")
end

-- EggQuest
local function farmEggQuest(worldName)
    print("🥚 EggQuest")

    -- ใช้โค้ดเดียวกับ EggQuest.lua standalone ทุกอย่าง
    local collectEggRemote = RS.Remotes.CollectEggRemote
    local eggsFolder = workspace.Interactions.Nodes.Eggs.ActiveNodes

    while not isMissionDone(worldName, "EggQuest") do
        local collected = 0

        for _, eggNode in ipairs(eggsFolder:GetChildren()) do
            if isMissionDone(worldName, "EggQuest") then break end

            local eggModel = eggNode:FindFirstChild("EggModel")
            if not eggModel then continue end
            local harvested = eggModel:FindFirstChild("Harvested")
            if not harvested or harvested.Value then continue end

            local root = getRoot()
            if not root then task.wait(0.5) continue end

            local eggId = eggNode.Name:match("%d+") or eggNode.Name
            local eggPos = eggModel:GetPivot().Position
            root.CFrame = CFrame.new(
                eggPos + Vector3.new(math.random(-10,10), math.random(5,15), math.random(-10,10)),
                eggPos
            )
            task.wait(2)

            harvested.Value = true
            task.wait(1)

            pcall(function() collectEggRemote:InvokeServer(eggId) end)
            print("🥚 collected:", eggNode.Name, "id:", eggId)
            collected += 1

            task.wait(5)
        end

        if collected == 0 then
            print("🥚 ไม่มีไข่พร้อม — รอ 5s")
            task.wait(5)
        end
    end

    print("✅ EggQuest done")
end

-- Harvest
local function farmHarvest(worldName)
    print("🌿 Harvest")
    local stop = false

    local ATTACK_SPEED     = 0.1
    local MULTI_HIT        = 5
    local COLLECT_INTERVAL = 0.2
    local TWEEN_SPEED      = 1
    local FARM_HEIGHT      = 20
    local MAX_KILL_WAIT    = 10

    -- ★ Harvest นับทุก LargeHarvestNode pickup (dump line 125433-125437)
    -- ★ Workspace path: workspace.Interactions.Nodes.{Food,Resources,BoneMeal}
    --   (dump line 125373-125377 — server tag LargeHarvestNode ทั้ง 4 folder รวม
    --   CloverCoins แต่ตัวนั้นเป็น event เฉพาะกาล ข้าม)
    local function scanFolder(folder, root, best)
        if not folder then return end
        for _, node in ipairs(folder:GetChildren()) do
            local toScan = { node }
            if node:IsA("Folder") then
                for _, sub in ipairs(node:GetChildren()) do table.insert(toScan, sub) end
            end
            for _, cand in ipairs(toScan) do
                local bb = cand:FindFirstChild("BillboardPart")
                if bb and not bb:IsA("BasePart") then bb = nil end
                if not bb then bb = cand:FindFirstChild("BillboardPart", true) end
                if bb then
                    local h = bb:FindFirstChild("Health")
                    if h and h:IsA("ValueBase") and h.Value > 0 then
                        local d = (root.Position - bb.Position).Magnitude
                        if d < best.dist then
                            best.dist   = d
                            best.target = { billboard = bb, health = h, distance = d }
                        end
                    end
                end
            end
        end
    end

    local function findFood()
        local root = getRoot()
        if not root then return nil end
        local nodes = workspace:FindFirstChild("Interactions")
            and workspace.Interactions:FindFirstChild("Nodes")
        if not nodes then return nil end
        local best = { target = nil, dist = math.huge }
        scanFolder(nodes:FindFirstChild("Food"),      root, best)
        scanFolder(nodes:FindFirstChild("Resources"), root, best)
        scanFolder(nodes:FindFirstChild("BoneMeal"),  root, best)
        return best.target
    end

    local function tweenTo(billboard, distance)
        local root = getRoot()
        if not root or not billboard then return end
        local target   = CFrame.new(billboard.Position + Vector3.new(0, FARM_HEIGHT, 0), billboard.Position)
        local duration = math.clamp(distance / 800, 0.5, TWEEN_SPEED)
        local startCF  = root.CFrame
        local steps    = math.max(math.ceil(duration / 0.05), 1)
        for i = 1, steps do
            local r = getRoot()
            if not r then break end
            r.CFrame = startCF:Lerp(target, math.sin(math.min(i / steps, 1) * math.pi / 2))
            task.wait(0.05)
        end
        local r = getRoot()
        if r then r.CFrame = target end
    end

    -- auto-collect (กรอง Food จาก cam + workspace เหมือน MAIN)
    local cam = workspace.CurrentCamera
    task.spawn(function()
        while not stop do
            task.wait(COLLECT_INTERVAL)
            local root = getRoot()
            if root then
                for _, item in ipairs(cam:GetChildren()) do
                    if item:IsA("Model") and item.Name:find("Food") then
                        local p = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
                        if p then pcall(function() p.CFrame = root.CFrame end) end
                    end
                end
                for _, item in ipairs(workspace:GetChildren()) do
                    if item:IsA("Model") and item.Name:find("Food") and not item:FindFirstChild("BillboardPart") then
                        local p = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
                        if p then pcall(function() p.CFrame = root.CFrame end) end
                    end
                end
            end
        end
    end)

    -- auto-attack background (breath → 0.12s → sound ตาม FoodNodeHitTest)
    local BREATH_SOUND_GAP = 0.12
    task.spawn(function()
        while not stop do
            task.wait(ATTACK_SPEED)
            local t = findFood()
            if t then
                local b, s = getDragon()
                if b then
                    for _ = 1, MULTI_HIT do
                        pcall(function() b:FireServer(true) end)
                        task.wait(BREATH_SOUND_GAP)
                        if s then pcall(function() s:FireServer("Breath", "Destructibles", t.billboard) end) end
                    end
                end
            end
        end
    end)

    -- main loop — scan ทั้ง Food + Resources + BoneMeal global → ถ้าไม่เจอจริงๆ
    -- (node respawn ระหว่าง SpawnDuration 60s) ก็แค่รอ ไม่ teleport มั่ว
    while not isMissionDone(worldName, "Harvest") do
        local foodData = findFood()
        if foodData then
            tweenTo(foodData.billboard, foodData.distance)
            local t0 = tick()
            while (tick() - t0) < MAX_KILL_WAIT do
                local ok, hp = pcall(function() return foodData.health.Value end)
                if not ok or hp <= 0 then break end
                task.wait(0.05)
            end
        else
            task.wait(1)
        end
    end

    stop = true
    print("✅ Harvest done")
end

-- KillMobs
local function farmKillMobs(worldName)
    print("⚔️ KillMobs")
    local stop = false

    local function findMob()
        return findNearestMobPart()
    end

    -- background: auto-collect (ChildAdded loop)
    local cam = workspace.CurrentCamera
    local function _snapLoop(item)
        task.spawn(function()
            local deadline = tick() + 2
            while item and item.Parent and tick() < deadline do
                local root = getRoot()
                if root then
                    local p = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart", true)
                    if p then pcall(function() p.CFrame = root.CFrame end) end
                end
                task.wait(0.05)
            end
        end)
    end
    cam.ChildAdded:Connect(function(item)
        if item:IsA("Model") then _snapLoop(item) end
    end)
    task.spawn(function()
        while not stop do
            task.wait(0.5)
            local root = getRoot()
            if not root then continue end
            for _, item in ipairs(cam:GetChildren()) do
                if item:IsA("Model") then
                    local p = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart", true)
                    if p then pcall(function() p.CFrame = root.CFrame end) end
                end
            end
        end
    end)

    local MOB_BREATH_GAP = 0.12
    task.spawn(function()
        while not stop do
            task.wait(0.1)
            local mob = findMob()
            local b, s = getDragon()
            if mob and b then
                pcall(function() b:FireServer(true) end)
                task.wait(MOB_BREATH_GAP)
                if s then pcall(function() s:FireServer("Breath", "Mobs", mob) end) end
            end
        end
    end)

    -- main loop: TP ไปหา mob
    while not isMissionDone(worldName, "KillMobs") do
        local mob = findMob()
        local root = getRoot()
        if mob and root then
            root.CFrame = CFrame.new(mob.Position + Vector3.new(0,10,0), mob.Position)
            task.wait(2)
        else
            task.wait(1)
        end
    end

    stop = true
    print("✅ KillMobs done")
end

-- KillBoss (แปลงจาก standalone ตรงๆ)
local function farmKillBoss(worldName)
    print("🐲 KillBoss")

    -- ── ใช้โค้ดเดียวกับ KillBoss.lua standalone ──

    local myFightId = os.time().."-"..LP.Name

    local function getMyInstance()
        local bossInst = workspace:FindFirstChild("Interactions")
            and workspace.Interactions:FindFirstChild("Boss")
            and workspace.Interactions.Boss:FindFirstChild("BossInstances")
        if not bossInst then return nil end
        for _, inst in ipairs(bossInst:GetChildren()) do
            local lives = inst:FindFirstChild("Lives")
            if lives and lives:FindFirstChild(LP.Name) then return inst end
        end
        return nil
    end

    local function isFightOver()
        local inst = getMyInstance()
        if not inst then return true end
        local dead = inst:FindFirstChild("Dead")
        local fe   = inst:FindFirstChild("FightEnd")
        return (dead and dead.Value == true) or (fe and fe.Value == true)
    end

    local function findBoss_()
        local inst = getMyInstance()
        if not inst then return nil end
        local activeBosses = workspace:FindFirstChild("ActiveBossModels")
        local boss = activeBosses and activeBosses:FindFirstChild(inst.Name)
        if not boss or not boss.PrimaryPart then return nil end
        local stageVal = inst:FindFirstChild("Stage")
        return { model=boss, part=boss.PrimaryPart, name=boss.Name, stage=stageVal and stageVal.Value or 1 }
    end

    -- ★ Stage 2: filter mob ที่อยู่ในระยะ N studs จาก boss (กัน Tundra/world mob)
    --   stage-2 mobs spawn ใกล้ boss arena, world mobs อยู่ห่าง → distance filter พอ
    local STAGE2_ARENA_RADIUS = 200
    local function findStageMob(bossPos)
        if not bossPos then return nil end
        local nearest, minDist = nil, math.huge
        local function consider(mobRoot)
            local part = getMobHitPart(mobRoot)
            if part then
                local d = (bossPos - part.Position).Magnitude
                if d < STAGE2_ARENA_RADIUS and d < minDist then
                    minDist = d
                    nearest = part
                end
            end
        end
        local nodes = workspace:FindFirstChild("Interactions")
            and workspace.Interactions:FindFirstChild("Nodes")
        local nm = nodes and nodes:FindFirstChild("Mobs")
        if nm then for _, c in ipairs(nm:GetChildren()) do consider(c) end end
        local mf = workspace:FindFirstChild("MobFolder")
        if mf then for _, c in ipairs(mf:GetChildren()) do consider(c) end end
        return nearest
    end

    -- create queue
    local createRemote = RS.Remotes:FindFirstChild("CreateBossQueueRemote")
    local startRemote  = RS.Remotes:FindFirstChild("StartBossQueueRemote")
    local tpRemote     = RS.Remotes:FindFirstChild("GetTeleportRemote")
    if not createRemote or not startRemote or not tpRemote then
        warn("KillBoss: ไม่เจอ remotes") return
    end

    local MAX_FAIL = 5
    local failCount = 0
    local ok_ = false
    while failCount < MAX_FAIL do
        local ok2, result = pcall(function() return createRemote:InvokeServer("Everyone") end)
        if ok2 then
            myFightId = type(result) == "string" and result or (os.time().."-"..LP.Name)
            print("🎫 FightId:", myFightId)
            ok_ = true
            break
        end
        failCount += 1
        task.wait(3)
    end
    if not ok_ then warn("KillBoss: สร้างห้องไม่ได้") return end

    task.wait(1)
    pcall(function() startRemote:InvokeServer() end)
    task.wait(2)
    pcall(function() tpRemote:InvokeServer("ToBossInstance", {FightId=myFightId, Spawn=true}) end)

    -- ★ รอ boss model + character respawn เสร็จ ก่อนเริ่ม attack loop (timeout 3s)
    print("🕐 รอ boss instance + character load...")
    local _bt = tick()
    while tick() - _bt < 3 do
        local activeBosses = workspace:FindFirstChild("ActiveBossModels")
        local boss = activeBosses and activeBosses:FindFirstChild(myFightId)
        local root = getRoot()
        if boss and boss.PrimaryPart and root and root.Parent then
            print(("✅ Boss + character ready (%.1fs)"):format(tick() - _bt))
            break
        end
        task.wait(0.3)
    end

    -- auto attack (เหมือน standalone)
    local currentTarget    = nil
    local currentTargetType = "Bosses"
    local stopped = false

    -- ★ Auto-remount loop: เช็คทุก 1.5s ถ้าตกมังกร (CurrentDragon == nil) → mount ใหม่
    task.spawn(function()
        while not stopped do
            task.wait(1.5)
            if not isMounted() then
                print("⚠ ตกมังกร → remount")
                mountDragon()
            end
        end
    end)

    task.spawn(function()
        repeat task.wait(0.1) until LP.Character
        local char    = LP.Character
        local dragons = char:WaitForChild("Dragons", 10)
        if not dragons then return end
        local dragon  = dragons:WaitForChild("1", 10)
        if not dragon  then return end
        local remotes = dragon:WaitForChild("Remotes", 10)
        if not remotes then return end
        local breath  = remotes:WaitForChild("BreathFireRemote", 10)
        local sound   = remotes:WaitForChild("PlaySoundRemote", 10)
        print("✅ Dragon loaded")
        while not stopped do
            task.wait(0.1)
            if currentTarget and currentTarget.part then
                if breath then pcall(function() breath:FireServer(true) end) end
                if sound  then pcall(function() sound:FireServer("Breath", currentTargetType, currentTarget.part) end) end
            end
        end
    end)

    -- fight loop (เหมือน standalone + หยุดเมื่อ mission done)
    local lastStage = 0
    while task.wait(0.5) and not isMissionDone(worldName, "KillBoss") do
        local bossData = findBoss_()
        if bossData then
            local root = getRoot()
            if root then
                if bossData.stage ~= lastStage then
                    print("📍 Stage", bossData.stage)
                    lastStage = bossData.stage
                end
                if bossData.stage == 2 then
                    -- ★ scan เฉพาะ stage mob ใกล้บอส (กัน Tundra wild mob)
                    local mob = findStageMob(bossData.part.Position)
                    if mob then
                        root.CFrame = CFrame.new(mob.Position + Vector3.new(0,10,0), mob.Position)
                        currentTarget     = { part = mob }
                        currentTargetType = "Mobs"
                        task.wait(1)
                    else
                        currentTarget = nil
                        task.wait(0.5)
                    end
                else
                    root.CFrame = CFrame.new(bossData.part.Position + Vector3.new(0,10,30), bossData.part.Position)
                    currentTarget     = bossData
                    currentTargetType = "Bosses"
                    task.wait(1)
                end
            end
        else
            currentTarget = nil
            if isFightOver() then
                print("✅ Fight จบ")
                break
            end
            task.wait(3)
        end
    end

    stopped = true
    print("✅ KillBoss done")
end

