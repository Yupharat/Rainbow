local mobRemote = remotes:WaitForChild("MobDamageRemote", 30)

local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNC = mt.__namecall
mt.__namecall = function(self, ...)
    if checkcaller() then return oldNC(self, ...) end
    local m = getnamecallmethod()
    if m == "Kick" then return nil end
    if m == "Teleport" or m == "TeleportAsync" then return nil end
    if m == "FireServer" or m == "InvokeServer" then
        if BLOCK_REMOTES[self.Name] then return nil end
        if mobRemote and self == mobRemote then return nil end   -- ★ godmode
    end
    return oldNC(self, ...)
end
setreadonly(mt, true)

