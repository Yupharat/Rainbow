local function findNearestFood()
    local root = getRoot()
    if not root then return nil end
    local folder = workspace:FindFirstChild("Interactions")
    folder = folder and folder:FindFirstChild("Nodes")
    folder = folder and folder:FindFirstChild("Food")
    if not folder then return nil end
    local nearest, minDist = nil, math.huge
    for _, node in ipairs(folder:GetChildren()) do
        local bb = node:FindFirstChild("BillboardPart")
        if bb then
            local h = bb:FindFirstChild("Health")
            if h and h.Value > 0 then
                local d = (root.Position - bb.Position).Magnitude
                if d < minDist and d < SCAN_RADIUS then
                    minDist = d
                    nearest = { billboard = bb, health = h, distance = d }
                end
            end
        end
    end
    return nearest
end

local function tweenToFood(billboard, distance)
    local root = getRoot()
    if not root or not billboard then return end
    local target   = CFrame.new(billboard.Position + Vector3.new(0, FARM_HEIGHT, 0), billboard.Position)
    local duration = math.clamp(distance / 800, 0.5, TWEEN_SPEED)
    local startCF  = root.CFrame
    local steps    = math.max(math.ceil(duration / 0.05), 1)
    for i = 1, steps do
        local r = getRoot()
        if not r then break end
        local a = math.min(i / steps, 1)
        r.CFrame = startCF:Lerp(target, math.sin(a * math.pi / 2))
        task.wait(0.05)
    end
    local r = getRoot()
    if r then r.CFrame = target end
end

task.spawn(function()
    local cam = workspace.CurrentCamera
    while task.wait(COLLECT_INTERVAL) do
        local root = getRoot()
        if root then
            for _, item in ipairs(cam:GetChildren()) do
                if item:IsA("Model") and item.Name:find("Food") then
                    local p = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
                    if p then pcall(function() p.CFrame = root.CFrame end) end
                end
            end
            for _, item in ipairs(workspace:GetChildren()) do
                if item:IsA("Model") and item.Name:find("Food") and not item:FindFirstChild("BillboardPart") then
                    local p = item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
                    if p then pcall(function() p.CFrame = root.CFrame end) end
                end
            end
        end
    end
end)

task.spawn(function()
    local char   = LP.Character
    local dragon = char:WaitForChild("Dragons"):WaitForChild("1")
    local breath = dragon.Remotes.BreathFireRemote
    local sound  = dragon.Remotes.PlaySoundRemote
    while true do
        local t = findNearestFood()
        if t then
            for _ = 1, MULTI_HIT do
                pcall(function()
                    breath:FireServer(true)
                    sound:FireServer("Breath", "Destructibles", t.billboard)
                end)
            end
        end
        task.wait(ATTACK_SPEED + math.random() * 0.2)
    end
end)

