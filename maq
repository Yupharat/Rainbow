-- ★ Ban detector — Kick + TeleportInitFailed → SetDescription("ban") + AccountChangeDone
local _banTriggered = false
local function triggerBan(reason)
    if _banTriggered then return end
    _banTriggered = true
    print("[main_og] 🚫 BAN DETECTED — " .. tostring(reason))
    pcall(function() _G.Horst_SetDescription("ban") end)
    pcall(function() _G.Horst_AccountChangeDone() end)
end

local BLOCK_REMOTES = {
    EventExportClientMetrics   = true,
    GameAnalyticsError         = true,
    GameAnalyticsRemoteConfigs = true,
    PostStrafeAnalyticsRemote  = true,
    FunctionGet                = true,
    AFKEvent                   = true,
}
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNC = mt.__namecall
mt.__namecall = function(self, ...)
    if checkcaller() then return oldNC(self, ...) end
    local m = getnamecallmethod()
    if m == "Kick" then
        local args = {...}
        triggerBan("Kick: " .. tostring(args[1] or "no reason"))
        return nil
    end
    if m == "Teleport" or m == "TeleportAsync" then return nil end
    if (m == "FireServer" or m == "InvokeServer") and BLOCK_REMOTES[self.Name] then return nil end
    return oldNC(self, ...)
end
setreadonly(mt, true)

