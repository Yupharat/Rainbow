elseif placeId == P_ID then
    local wpIdx = 1
    local preStart = tick()
    while task.wait(0.2) do
        if tick() - preStart >= 3000 then
            for _, item in ipairs(res:GetChildren()) do
                if item.Value and item.Value > 0 then
                    pcall(function() sellRemote:FireServer({ Amount = item.Value, ItemName = item.Name }) end)
                end
            end
            task.wait(1)
            tpOrigins()
            break
        end

        if res.Coconut.Value >= 10000 or res.Avacado.Value >= 10000 or res.CacaoBean.Value >= 10000 then
            for _, item in ipairs(res:GetChildren()) do
                if item.Value and item.Value > 0 then
                    pcall(function() sellRemote:FireServer({ Amount = item.Value, ItemName = item.Name }) end)
                end
            end
            task.wait(1)
            tpOrigins()
            break
        end

        local foodData = findNearestFood()
        if foodData then
            tweenToFood(foodData.billboard, foodData.distance)
            local t0 = tick()
            while (tick() - t0) < MAX_KILL_WAIT do
                local ok, hp = pcall(function() return foodData.health.Value end)
                if not ok or hp <= 0 then break end
                task.wait(0.05)
            end
        else
            local root = getRoot()
            if root then
                root.CFrame = CFrame.new(waypoints[wpIdx])
            end
            wpIdx = wpIdx % #waypoints + 1
            task.wait(1)
        end
    end

else
    tpPrehistoric()
end
