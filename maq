task.spawn(function()
    local SAFE_ANCESTOR = workspace:FindFirstChild("Interactions")

    local function isUnderSafe(obj)
        local p = obj.Parent
        while p do
            if p == SAFE_ANCESTOR then return true end
            p = p.Parent
        end
        return false
    end

    local ANIM_CLASS = { KeyframeSequence = true }
    local LIGHT_FX   = { ParticleEmitter = true, PointLight = true, Beam = true, Trail = true, Fire = true, Smoke = true }
    local DECO_NAMES = { Boulder2 = true, GlowingRuins = true, Ruins = true, Archway = true, HillRuins = true, SwampRuins = true }

    local batch, count = {}, 0
    for _, v in ipairs(workspace:GetDescendants()) do
        local shouldDelete = false

        if ANIM_CLASS[v.ClassName] then
            shouldDelete = true
        elseif v.Name == "AnimSaves" and v:IsA("ObjectValue") then
            shouldDelete = true
        elseif LIGHT_FX[v.ClassName] and not isUnderSafe(v) then
            shouldDelete = true
        elseif v:IsA("MeshPart") and DECO_NAMES[v.Name] and not isUnderSafe(v) then
            shouldDelete = true
        end

        if shouldDelete then
            table.insert(batch, v)
            count += 1
            if count % 300 == 0 then task.wait() end
        end
    end

    for _, v in ipairs(batch) do
        pcall(function() if v and v.Parent then v:Destroy() end end)
    end

    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    local Lighting = game:GetService("Lighting")
    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
            v:Destroy()
        end
    end
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9

    workspace.DescendantAdded:Connect(function(obj)
        if obj:IsA("ParticleEmitter") or obj:IsA("Beam") or
           obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") then
            pcall(function() obj:Destroy() end)
        elseif obj:IsA("Texture") or obj:IsA("Decal") then
            pcall(function() obj:Destroy() end)
        end
    end)

    game:GetService("RunService"):Set3dRenderingEnabled(false)
end)

